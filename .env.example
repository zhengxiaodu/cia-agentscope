OPENAI_API_KEY=your-openai-api-key
BOCHA_API_KEY=sk-b2456820150d48a68c15a0f76ded1eef

# JWT 鉴权配置
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRE_HOURS=8

# 第三方管理系统登录校验接口
# AUTH_MOCK=true 时使用内置模拟数据,生产环境应改为 false 并配置真实接口
AUTH_MOCK=true
AUTH_API_URL=https://example.com/api/auth/verify
AUTH_API_KEY=your-third-party-auth-api-key

# Redis 会话存储配置
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400

# MySQL 会话持久化配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=agentscope
MYSQL_DSN=mysql://root:your-mysql-password@localhost:3306/agentscope
UPLOAD_MAX_SIZE_MB=10

# Langfuse 可观测性配置（留空则不启用追踪）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# 管理中心配置（用户鉴权 / 意图卡片 地址分离）
MNG_AUTH_URL=
MNG_INTENT_URL=

# 外部技能目录（mng系统外部意图关联的skill存放路径）
EXTERNAL_SKILLS_DIR=

# 知识库配置
RAGFLOW_API_KEY=
RAGFLOW_BASE_URL=